# Football Prediction System - Production Template

# Core football data
API_FOOTBALL_KEY=your_api_sports_key
FOOTBALL_DATA_KEY=your_football_data_key
ODDS_API_KEY=your_odds_api_key
# optional aliases also supported:
# API_FOOTBALL_API_KEY=...
# FOOTBALL_DATA_API_KEY=...
# THE_ODDS_API_KEY=...

# Optional API overrides
API_FOOTBALL_BASE=https://v3.football.api-sports.io

# LLM relay (OpenAI-compatible)
OPENAI_BASE_URL=https://nan.meta-api.vip/v1
OPENAI_API_KEY=your_openai_relay_key
OPENAI_MODEL=gpt-4o-mini
# aliases supported: OPENAI_RELAY_URL / OPENAI_RELAY_KEY

# Gemini relay (OpenAI-compatible)
GEMINI_BASE_URL=https://once.novai.su/v1
GEMINI_API_KEY=your_gemini_relay_key
GEMINI_MODEL=gemini-2.0-flash
# aliases supported: GEMINI_RELAY_URL / GEMINI_RELAY_KEY

# Runtime options
LOG_LEVEL=INFO
